{% extends "layouts/page-with-back-link.njk" %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "macros/meritsDecisionTag.njk" import meritsDecisionTag %}

{% block pageContent %}

<div class="govuk-width-container">

    <p class="govuk-body govuk-!-margin-bottom-2">
        {{ govukTag({
            text: statusTag.text,
            classes: statusTag.classes
        }) }}
    </p>

    <h1 class="govuk-heading-xl">{{ application.laaReference }}</h1>

    {% set applicationDetailsHtml %}
        <h2 class="govuk-heading-m">Overview</h2>
        {{ govukSummaryList({
            rows: [
                {
                    key: { text: "Application type" },
                    value: { text: application.applicationType }
                },
                {
                    key: { text: "Certificate type" },
                    value: { text: proceedings[0].certificateType }
                },
                {
                    key: { text: "Merits application" },
                    value: { html: meritsDecisionTag(application.overallDecision) }
                }
            ]
        }) }}
        <h2 class="govuk-heading-m">Proceedings</h2>
        {{ govukSummaryList({
            card: {
                title: {
                    text: "1. " ~ proceedings[0].proceedingDescription
                }
            },
            rows: [
                {
                    key: { text: "Client role" },
                    value: { text: proceedings[0].clientInvolvementType }
                },
                {
                    key: { text: "Level of service" },
                    value: { text: proceedings[0].levelOfService }
                },
                {
                    key: { text: "Scope limitation" },
                    value: { text: proceedings[0].scopeLimitationHeading }
                },
                {
                    key: { text: "Cost limit" },
                    value: { text: proceedings[0].substantiveCostLimitation }
                }
            ]
        }) }}
        <h2 class="govuk-heading-m">Uploaded evidence</h2>
        {{ govukSummaryList({
            card: {
                title: {
                    text: "Supporting evidence"
                }
            },
            rows: [
                {
                    key: { text: "Coroners letter" },
                    value: { html: '<a href="#">Inquest ABC Coroners letter.pdf</a>' }
                }
            ]
        }) }}
        {{ govukButton({
            text: "Make assessment",
            href: "/applications/" ~ application.laaReference ~ "/decision"
        }) }}
    {% endset %}

    {% set peopleHtml %}
        {% set clientRows = [
            {
                key: { text: "First name" },
                value: { text: application.client.clientFirstName }
            },
            {
                key: { text: "Last name" },
                value: { text: application.client.clientLastName }
            },
            {
                key: { text: "Date of birth" },
                value: { text: application.client.dateOfBirth }
            },
            {
                key: { text: "National Insurance number" },
                value: { text: application.client.nationalInsuranceNumber }
            },
            {
                key: { text: "Address" },
                value: { html: clientHomeAddressDisplay }
            },
            {
                key: { text: "Correspondence address" },
                value: { html: clientCorrespondenceAddressDisplay }
            },
            {
                key: { text: "Relationship to deceased" },
                value: { text: application.deceased.clientRelationshipToDeceased }
            }
        ] %}

        {% if careOfRecipientDisplay %}
            {% set clientRows = clientRows.concat([
                {
                    key: { text: "Care of recipient" },
                    value: { html: careOfRecipientDisplay }
                }
            ]) %}
        {% endif %}

        {{ govukSummaryList({
            card: {
                title: {
                    text: "Client"
                }
            },
            rows: clientRows
        }) }}
        {{ govukSummaryList({
            card: {
                title: {
                    text: "Deceased"
                }
            },
            rows: [
                {
                    key: { text: "First name" },
                    value: { text: application.deceased.deceasedFirstName }
                },
                {
                    key: { text: "Last name" },
                    value: { text: application.deceased.deceasedLastName }
                },
                {
                    key: { text: "Date of death" },
                    value: { text: application.deceased.deceasedDateOfDeath }
                },
                {
                    key: { text: "Date of birth" },
                    value: { text: application.deceased.deceasedDateOfBirth }
                },
                {
                    key: { text: "Inquest ID" },
                    value: { text: application.deceased.coronersReference }
                },
                {
                    key: { text: "Additional inquest info" },
                    value: { text: application.deceased.furtherInformation }
                }
            ]
        }) }}
        {{ govukSummaryList({
            card: {
                title: {
                    text: "Provider"
                }
            },
            rows: [
                {
                    key: { text: "Firm name" },
                    value: { text: application.provider.firmName }
                },
                {
                    key: { text: "Account number" },
                    value: { text: application.provider.accountNumber }
                },
                {
                    key: { text: "Address" },
                    value: { text: application.provider.emailAddress }
                }
            ]
        }) }}
        {% set publicBodyRows = [] %}
        {% for body in application.publicBodies %}
            {% set publicBodyRows = publicBodyRows.concat([{ key: { text: body.publicBodyDescription } }]) %}
        {% endfor %}
        {{ govukSummaryList({
            card: {
                title: {
                    text: "Interested parties"
                }
            },
            rows: publicBodyRows
        }) }}
        {{ govukButton({
            text: "Make assessment",
            href: "/applications/" ~ application.laaReference ~ "/decision"
        }) }}
    {% endset %}

    {{ govukTabs({
        items: [
            {
                label: "Application details",
                id: "application-details",
                panel: { html: applicationDetailsHtml }
            },
            {
                label: "People",
                id: "people",
                panel: { html: peopleHtml }
            },
            {
                label: "History",
                id: "history",
                panel: { html: "" }
            }
        ]
    }) }}

</div>

{% endblock %}